SYSTEM_NAME=components
COMPONENT_ID=security_monitor
BROKER_USER=security_monitor
BROKER_PASSWORD=security_monitor_secret
POLICY_ADMIN_SENDER=security_monitor_admin
# SECURITY_POLICIES задаётся вручную. Скопируйте строку ниже в .env или в переменные окружения.
SECURITY_POLICIES=[{"sender":"limiter","topic":"${SYSTEM_NAME}.navigation","action":"get_state"},{"sender":"limiter","topic":"${SYSTEM_NAME}.telemetry","action":"get_state"},{"sender":"limiter","topic":"${SYSTEM_NAME}.emergensy","action":"limiter_event"},{"sender":"limiter","topic":"${SYSTEM_NAME}.journal","action":"log_event"},{"sender":"mission_handler","topic":"${SYSTEM_NAME}.autopilot","action":"mission_load"},{"sender":"mission_handler","topic":"${SYSTEM_NAME}.limiter","action":"mission_load"},{"sender":"mission_handler","topic":"${SYSTEM_NAME}.journal","action":"log_event"},{"sender":"autopilot","topic":"${SYSTEM_NAME}.navigation","action":"get_state"},{"sender":"autopilot","topic":"${SYSTEM_NAME}.motors","action":"set_target"},{"sender":"autopilot","topic":"${SYSTEM_NAME}.sprayer","action":"set_spray"},{"sender":"autopilot","topic":"${SYSTEM_NAME}.journal","action":"log_event"},{"sender":"autopilot","topic":"${ORVD_TOPIC}","action":"request_takeoff"},{"sender":"navigation","topic":"${SITL_TELEMETRY_REQUEST_TOPIC}","action":"__raw__"},{"sender":"navigation","topic":"${SYSTEM_NAME}.journal","action":"log_event"},{"sender":"emergensy","topic":"${SYSTEM_NAME}.motors","action":"land"},{"sender":"emergensy","topic":"${SYSTEM_NAME}.sprayer","action":"set_spray"},{"sender":"emergensy","topic":"${SYSTEM_NAME}.journal","action":"log_event"},{"sender":"emergensy","topic":"${SYSTEM_NAME}.security_monitor","action":"isolation_status"},{"sender":"telemetry","topic":"${SYSTEM_NAME}.motors","action":"get_state"},{"sender":"telemetry","topic":"${SYSTEM_NAME}.sprayer","action":"get_state"},{"sender":"telemetry","topic":"${SYSTEM_NAME}.navigation","action":"get_state"},{"sender":"sprayer","topic":"${SYSTEM_NAME}.journal","action":"log_event"},{"sender":"motors","topic":"${SITL_COMMANDS_TOPIC}","action":"__raw__"},{"sender":"nsu","topic":"${SYSTEM_NAME}.mission_handler","action":"load_mission"},{"sender":"nsu","topic":"${SYSTEM_NAME}.mission_handler","action":"validate_only"},{"sender":"orvd","topic":"${SYSTEM_NAME}.mission_handler","action":"load_mission"},{"sender":"orvd","topic":"${SYSTEM_NAME}.mission_handler","action":"validate_only"}]

# Таймаут реального request к целевому компоненту внутри МБ
SECURITY_MONITOR_PROXY_REQUEST_TIMEOUT_S=10.0
