COMPONENT_ID=navigation

NAVIGATION_POLL_INTERVAL_S=0.1
# Цепочка navigation → МБ → SITL messaging → Redis; 1 с часто даёт таймауты под нагрузкой
NAVIGATION_REQUEST_TIMEOUT_S=5.0
SITL_DRONE_ID=drone_001
# Иначе fallback — SITL_TOPIC (v1.SITL...), не совпадает с sitl-messaging (sitl.telemetry.request)
SITL_TELEMETRY_REQUEST_TOPIC=sitl.telemetry.request
