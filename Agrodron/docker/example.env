# Настройки инфраструктуры брокера
BROKER_TYPE=kafka

KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
MQTT_PORT=1883

# Админ — всегда есть в Kafka. Используйте для тестов и для сервисов без своих кредов.
ADMIN_USER=admin
ADMIN_PASSWORD=admin_secret_123

# Опционально: отдельные пользователи для компонентов.
# Для system-режима значения обычно подставляются автоматически из
# systems/<system>/src/<component>/.env через scripts/prepare_system.py.
COMPONENT_USER_A=
COMPONENT_PASSWORD_A=
COMPONENT_USER_B=
COMPONENT_PASSWORD_B=

DOCKER_NETWORK=drones_net
