# Параметры формирования топиков (v1.SystemName.InstanceID.component)
TOPIC_VERSION=v1
SYSTEM_NAME=Agrodron
INSTANCE_ID=Agrodron001

# Брокер: учётные данные админа подмешиваются из корня репозитория docker/example.env (или docker/.env) при make prepare
BROKER_TYPE=mqtt
MQTT_BROKER=mosquitto

# Топики внешних систем
ORVD_TOPIC=v1.ORVD.ORVD001.main
NUS_TOPIC=v1.gcs.1.drone_manager
DRONEPORT_TOPIC=v1.drone_port.1.drone_manager
# DronePort drone_manager: model в request_landing; заряд для request_charging / request_takeoff, если нет в навигации
# DRONEPORT_DRONE_MODEL=agrodron
# DRONEPORT_CHARGING_BATTERY_DEFAULT=50
# DRONEPORT_TAKEOFF_BATTERY_DEFAULT=95

SITL_TOPIC=v1.SITL.SITL001.main

# SITL (внешняя система, протокол без поля action)
SITL_COMMANDS_TOPIC=sitl.commands
SITL_TELEMETRY_REQUEST_TOPIC=sitl.telemetry.request
# Вход verifier SITL (HOME в формате sitl-drone-home.json); иначе только SITL_TOPIC не заполняет Redis
SITL_VERIFIER_HOME_TOPIC=sitl-drone-home
