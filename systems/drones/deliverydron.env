# Delivery drone system identity (broker topics).
# TOPIC_SCHEME=legacy -> ${TOPIC_VERSION}.${SYSTEM_NAME}.${INSTANCE_ID}.${COMPONENT_ID}
# TOPIC_SCHEME=components -> components.${SYSTEM_NAME}.${COMPONENT_ID}
# TOPIC_PREFIX, if set, overrides both schemes (prefix without component).
SYSTEM_NAME=deliverydron
DELIVERYDRON_ROOT=systems/deliverydron
TOPIC_SCHEME=legacy
TOPIC_PREFIX=
TOPIC_VERSION=v1
INSTANCE_ID=Delivery001
