# Настройки инфраструктуры брокера
BROKER_TYPE=mqtt

KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
MQTT_PORT=1883

# Админ — всегда есть в Kafka.
ADMIN_USER=admin
ADMIN_PASSWORD=admin_secret_123

DOCKER_NETWORK=drones_net

# Идентификатор инстанса системы
INSTANCE_ID=1

# SITL: HOME при взлёте публикует drone_manager (тот же топик, что verifier / Agrodron)
SITL_HOME_TOPIC=sitl-drone-home
SITL_DEFAULT_HOME_ALT=10.0