SYSTEM_NAME=components
COMPONENT_ID=autopilot
BROKER_USER=autopilot
BROKER_PASSWORD=autopilot_secret

# Параметры автопилота (env-driven)
AUTOPILOT_CONTROL_INTERVAL_S=0.2
AUTOPILOT_NAV_POLL_INTERVAL_S=0.2
AUTOPILOT_REQUEST_TIMEOUT_S=2.0

# Action навигации для запроса snapshot
NAVIGATION_GET_STATE_ACTION=get_state

