# ---------------------------------------------------------------------------
# SITL-module: сеть drones_net + Mosquitto (hostname mosquitto в той же сети)
# ---------------------------------------------------------------------------
# make sitl-up: если рядом есть cyber_drons/docker/.env — sitl.env собирается из него
# (ADMIN_USER / ADMIN_PASSWORD / DOCKER_NETWORK / MQTT_PORT). Иначе — копия этого файла.
# ---------------------------------------------------------------------------

DOCKER_NETWORK=drones_net

BROKER_BACKEND=mqtt

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_QOS=1
MQTT_USERNAME=admin
MQTT_PASSWORD=admin_secret_123

REDIS_URL=redis://sitl_redis:6379

POSITION_REQUEST_TOPIC=sitl.telemetry.request
POSITION_RESPONSE_TOPIC=sitl.telemetry.response

KAFKA_SERVERS=kafka:29092
